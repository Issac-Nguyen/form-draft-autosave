{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "types": ["chrome", "vitest/globals", "@testing-library/jest-dom", "node"],
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true
  },
  "include": ["src", "tests"]
}
